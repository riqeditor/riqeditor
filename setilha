<script>
  const cursor = document.getElementById('cursor');
  const ring = document.getElementById('cursor-ring');
  document.addEventListener('mousemove', e => {
    cursor.style.left = e.clientX + 'px';
    cursor.style.top = e.clientY + 'px';
    ring.style.left = e.clientX + 'px';
    ring.style.top = e.clientY + 'px';
  });
  document.querySelectorAll('a, button, .grid-item, .play-btn').forEach(el => {
    el.addEventListener('mouseenter', () => { ring.style.width = '56px'; ring.style.height = '56px'; ring.style.borderColor = 'rgba(200,16,46,0.7)'; });
    el.addEventListener('mouseleave', () => { ring.style.width = '36px'; ring.style.height = '36px'; ring.style.borderColor = 'rgba(200,16,46,0.4)'; });
  });

  const videos = [
    'https://youtube.com/shorts/m0T6y_TZxyo',
    'https://youtube.com/shorts/oONhjS6jHK8',
    'https://youtube.com/shorts/-G_okt6MOjs',
    'https://youtube.com/shorts/opbP6J8A0ls',
    'https://youtube.com/shorts/TCuviCTda6s',
    'https://youtube.com/shorts/yKObOAAnHhk',
    'https://youtube.com/shorts/nXMuFBIKHdc'
  ];
  const titles = ['Ads 01','Ads 02','Ads 03','Ads 04','Ads 05','Ads 06','Ads 07'];

  function getEmbedUrl(url) {
    try {
      if (url.includes('youtube.com/shorts/')) {
        const v = url.split('shorts/')[1].split('?')[0];
        return `https://www.youtube.com/embed/${v}?autoplay=1`;
      }
      if (url.includes('youtube.com/watch')) {
        const v = new URL(url).searchParams.get('v');
        return `https://www.youtube.com/embed/${v}?autoplay=1`;
      }
      if (url.includes('youtu.be/')) {
        const v = url.split('youtu.be/')[1].split('?')[0];
        return `https://www.youtube.com/embed/${v}?autoplay=1`;
      }
      if (url.includes('vimeo.com/')) {
        const v = url.split('vimeo.com/')[1].split('?')[0];
        return `https://player.vimeo.com/video/${v}?autoplay=1`;
      }
    } catch(e) {}
    return null;
  }

  function openReelVideo() {
    document.getElementById('modal-video-content').innerHTML = `<iframe src="https://www.youtube.com/embed/NUisPSy8BYM?autoplay=1" allowfullscreen style="width:100%;height:100%;border:none;"></iframe>`;
    document.getElementById('modal-title').textContent = 'VSL';
    document.getElementById('video-modal').classList.add('open');
  }

  let currentTarget = null;

  function openUrlModal(target) { currentTarget = target; }
  function closeUrlModal() { document.getElementById('url-modal').classList.remove('open'); currentTarget = null; }
  function saveUrl() { closeUrlModal(); }

  function openVideo(index) {
    const url = videos[index];
    if (!url) return;
    const embed = getEmbedUrl(url);
    if (!embed) return;
    document.getElementById('modal-video-content').innerHTML = `<iframe src="${embed}" allowfullscreen style="width:100%;height:100%;border:none;"></iframe>`;
    document.getElementById('modal-title').textContent = titles[index];
    document.getElementById('video-modal').classList.add('open');
  }

  function closeModal() {
    document.getElementById('video-modal').classList.remove('open');
    document.getElementById('modal-video-content').innerHTML = '';
  }

  document.getElementById('video-modal').addEventListener('click', function(e) {
    if (e.target === this) closeModal();
  });
  document.getElementById('url-modal').addEventListener('click', function(e) {
    if (e.target === this) closeUrlModal();
  });
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') { closeModal(); closeUrlModal(); }
  });
</script>
